{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "collect: 일별 스냅샷 수집",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/collect/daily_snapshot.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "showcase 1: 전처리",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/analyze/showcase/1_preprocess.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "showcase 2: 집계 파일 생성",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/analyze/showcase/2_aggregate.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": { "PYTHONIOENCODING": "utf-8" }
        },
        {
            "name": "showcase 3: 분석 결과 출력",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/analyze/showcase/3_stats.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": { "PYTHONIOENCODING": "utf-8" }
        },
        {
            "name": "dashboard: 대시보드 실행 (Streamlit)",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/dashboard/app.py",
                "--server.headless", "false"
            ],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
