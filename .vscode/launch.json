{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "collect: 유저 상세 정보 수집",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/collect/user_detail.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "collect: 일별 스냅샷 수집",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/collect/daily_snapshot.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "exp_analysis 1: 전처리",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/exp_analysis/1_preprocess.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "exp_analysis 2: 집계 파일 생성",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/exp_analysis/2_aggregate.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": { "PYTHONIOENCODING": "utf-8" }
        },
        {
            "name": "exp_analysis 3: 분석 결과 출력",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/exp_analysis/3_stats.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": { "PYTHONIOENCODING": "utf-8" }
        },
        {
            "name": "user_clustering segmentation 1: 클러스터링",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/user_clustering/segmentation/1_cluster.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": { "PYTHONIOENCODING": "utf-8" }
        },
        {
            "name": "user_clustering segmentation 2: 클러스터 프로파일",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/user_clustering/segmentation/2_profile.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": { "PYTHONIOENCODING": "utf-8" }
        },
        {
            "name": "user_clustering survival 1: 생존 분석 전처리",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/user_clustering/survival/1_preprocess.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": { "PYTHONIOENCODING": "utf-8" }
        },
        {
            "name": "user_clustering survival 2: 생존 분석",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/user_clustering/survival/2_analyze.py",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": { "PYTHONIOENCODING": "utf-8" }
        },
        {
            "name": "dashboard: 경험치 분석 (Streamlit)",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/exp_analysis/dashboard/app.py",
                "--server.headless", "false"
            ],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "dashboard: 유저 클러스터링 (Streamlit)",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/user_clustering/dashboard/app.py",
                "--server.headless", "false",
                "--server.port", "8502"
            ],
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
